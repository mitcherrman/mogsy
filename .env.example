# Combat/quiz backend
VITE_COMBAT_API_URL=http://127.0.0.1:8000

# Stripe price IDs (optional overrides — omit to use the live IDs baked into Shop.tsx).
# For test mode, create test-mode prices in the Stripe Dashboard and put their IDs here,
# and set STRIPE_SECRET_KEY (test key) + STRIPE_WEBHOOK_SECRET on Supabase edge functions.
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=

# League Mogsy Pro (/lol/pro) — $4.99/mo launch price. REQUIRED for League Pro
# checkout: there is deliberately no fallback to the old Shop prices above.
# Until this is set, /lol/pro shows "Mogsy Pro checkout is coming soon."
VITE_STRIPE_LOL_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
VITE_STRIPE_GIFT_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_GIFT_PRO_ANNUAL_PRICE_ID=
VITE_STRIPE_WINBACK_COUPON_ID=
VITE_STRIPE_PACK_50_PRICE_ID=
VITE_STRIPE_PACK_200_PRICE_ID=
VITE_STRIPE_PACK_500_PRICE_ID=
VITE_STRIPE_PACK_1500_PRICE_ID=
VITE_STRIPE_PACK_5000_PRICE_ID=

# Advertising (preliminary, provider-neutral — see docs/advertising.md).
# Safe defaults: everything off. VITE_ADS_ENABLED is the global kill switch.
# No Google/AdSense scripts or IDs are involved in any of these flags.
VITE_ADS_ENABLED=false
VITE_THIRD_PARTY_ADS_ENABLED=false
VITE_HOUSE_ADS_ENABLED=false
VITE_AD_PLACEHOLDERS_ENABLED=false
# Optional override for the AdSense publisher ID. When unset, the loader reads
# the account-verification <meta name="google-adsense-account"> in index.html
# (the real, legitimate account: ca-pub-9823769047605421). Missing/invalid
# values fail closed — no ID is ever fabricated. Not a secret.
VITE_ADSENSE_PUBLISHER_ID=
